# Normalise line endings — LF in the repo, checked out per-platform.
* text=auto eol=lf

# C#/project files
*.cs      text diff=csharp
*.csproj  text
*.props   text
*.targets text
*.sln     text eol=crlf

# Docs
*.md   text
*.json text
*.yml  text
*.yaml text

# Binary
*.png binary
*.ico binary
*.snk binary
