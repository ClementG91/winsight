<Window x:Class="WinSight.Dashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WinSight.Dashboard"
        xmlns:automation="clr-namespace:System.Windows.Automation;assembly=PresentationCore"
        Title="{Binding [WindowTitle], Source={x:Static local:LocalizationManager.Instance}}"
        Icon="Assets/winsight-logo.png" Height="780" Width="1220"
        MinHeight="620" MinWidth="960" Background="#F1F5F9"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="78" />
            <RowDefinition Height="*" />
            <RowDefinition Height="34" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#0F172A" Padding="26,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Image Width="50" Height="50" Margin="0,0,14,0"
                           Source="Assets/winsight-logo.png" Stretch="Uniform"
                           automation:AutomationProperties.Name="WinSight" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="WinSight" Foreground="White" FontSize="24" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding [AppTagline], Source={x:Static local:LocalizationManager.Instance}}"
                                   Foreground="#CBD5E1" FontSize="13" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="SettingsButton" Height="32" Margin="0,0,16,0" Padding="12,0"
                            VerticalContentAlignment="Center"
                            Content="{Binding [SettingsButton], Source={x:Static local:LocalizationManager.Instance}}"
                            Click="SettingsButton_Click"
                            automation:AutomationProperties.Name="{Binding [SettingsAutomation], Source={x:Static local:LocalizationManager.Instance}}" />
                    <TextBlock Text="{Binding [LanguageLabel], Source={x:Static local:LocalizationManager.Instance}}"
                               Foreground="#CBD5E1" VerticalAlignment="Center" Margin="0,0,7,0" />
                    <ComboBox x:Name="LanguagePicker" Width="112" Height="32" Margin="0,0,14,0"
                              VerticalContentAlignment="Center" Padding="7,0"
                              DisplayMemberPath="NativeName" SelectedValuePath="Code"
                              SelectionChanged="LanguagePicker_SelectionChanged"
                              automation:AutomationProperties.Name="{Binding [LanguagePickerAutomation], Source={x:Static local:LocalizationManager.Instance}}" />
                    <Border Background="#163A2D" CornerRadius="14" Padding="12,6">
                        <TextBlock Text="{Binding [LocalAnalysis], Source={x:Static local:LocalizationManager.Instance}}"
                                   Foreground="#86EFAC" FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Margin="6,2,6,12">
                        <TextBlock Text="{Binding [ChooseCheckTitle], Source={x:Static local:LocalizationManager.Instance}}"
                                   FontSize="17" FontWeight="SemiBold" Foreground="#0F172A" />
                        <TextBlock Text="{Binding [ChooseCheckSubtitle], Source={x:Static local:LocalizationManager.Instance}}"
                                   Margin="0,5,0,0" TextWrapping="Wrap" Foreground="#64748B" FontSize="12" />
                    </StackPanel>

                    <ListBox x:Name="ToolPicker" Grid.Row="1" BorderThickness="0" Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             SelectionChanged="ToolPicker_SelectionChanged"
                             automation:AutomationProperties.Name="{Binding [ToolPickerAutomation], Source={x:Static local:LocalizationManager.Instance}}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5,7" ToolTip="{Binding Description}">
                                    <TextBlock Text="{Binding Label}" FontWeight="SemiBold" Foreground="#0F172A" />
                                    <TextBlock Text="{Binding ShortDescription}" Margin="0,2,0,0" FontSize="11"
                                               Foreground="#64748B" TextWrapping="Wrap" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Margin="4,12,4,2">
                        <CheckBox x:Name="FlaggedOnly" IsChecked="True" Margin="2,0,2,10"
                                  Content="{Binding [FlaggedOnly], Source={x:Static local:LocalizationManager.Instance}}"
                                  ToolTip="{Binding [FlaggedOnlyTooltip], Source={x:Static local:LocalizationManager.Instance}}" />
                        <Button x:Name="ScanButton" Height="42"
                                Content="{Binding [StartAnalysis], Source={x:Static local:LocalizationManager.Instance}}"
                                Background="#2563EB" Foreground="White" BorderThickness="0"
                                FontWeight="SemiBold" Click="ScanButton_Click"
                                automation:AutomationProperties.Name="{Binding [StartAnalysisAutomation], Source={x:Static local:LocalizationManager.Instance}}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="18">
                    <DockPanel>
                        <StackPanel>
                            <TextBlock x:Name="SelectedToolTitle" FontSize="21" FontWeight="SemiBold" Foreground="#0F172A" />
                            <TextBlock x:Name="SelectedToolDescription" Margin="0,5,0,0" Foreground="#475569"
                                       TextWrapping="Wrap" MaxWidth="680" />
                        </StackPanel>
                        <Button x:Name="WindowsToolButton" DockPanel.Dock="Right"
                                Content="{Binding [OpenWindowsTool], Source={x:Static local:LocalizationManager.Instance}}"
                                VerticalAlignment="Center" Visibility="Collapsed" Click="WindowsToolButton_Click" />
                    </DockPanel>
                </Border>

                <Border x:Name="ProgressPanel" Grid.Row="1" Margin="0,12,0,0" Background="#EFF6FF"
                        BorderBrush="#BFDBFE" BorderThickness="1" CornerRadius="10" Padding="14" Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="ProgressText" VerticalAlignment="Center"
                                       Foreground="#1E3A8A" FontWeight="SemiBold" />
                            <Button x:Name="CancelButton" Grid.Column="1" Margin="12,0,0,0"
                                    Content="{Binding [StopAnalysis], Source={x:Static local:LocalizationManager.Instance}}"
                                    ToolTip="{Binding [StopAfterStep], Source={x:Static local:LocalizationManager.Instance}}"
                                    Padding="12,4" MinWidth="0" HorizontalAlignment="Right"
                                    Visibility="Collapsed" Click="CancelButton_Click" />
                        </Grid>
                        <ProgressBar x:Name="ScanProgressBar" Grid.Row="1" Height="8" Margin="0,10,0,0"
                                     Minimum="0" Maximum="100" Foreground="#2563EB"
                                     automation:AutomationProperties.Name="{Binding [ProgressAutomation], Source={x:Static local:LocalizationManager.Instance}}" />
                    </Grid>
                </Border>

                <DockPanel Grid.Row="2" Margin="2,14,2,9">
                    <TextBlock x:Name="SummaryText" VerticalAlignment="Center" FontSize="15" FontWeight="SemiBold"
                               Foreground="#334155"
                               Text="{Binding [ReadySummary], Source={x:Static local:LocalizationManager.Instance}}" />
                </DockPanel>

                <Border x:Name="FirewallActionsPanel" Grid.Row="3" Margin="0,0,0,12" Visibility="Collapsed"
                        Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12" Padding="14,12">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold" Foreground="#0F172A"
                                   Text="{Binding [FirewallControlsTitle], Source={x:Static local:LocalizationManager.Instance}}" />
                        <TextBlock x:Name="FirewallControlsHint" Margin="0,3,0,0" FontSize="12" Foreground="#64748B"
                                   TextWrapping="Wrap"
                                   Text="{Binding [FirewallControlsHint], Source={x:Static local:LocalizationManager.Instance}}" />
                        <WrapPanel Margin="0,10,0,0">
                            <Button x:Name="FirewallBlockAppButton" Margin="0,4,10,4" Padding="12,5" MinWidth="120"
                                    Content="{Binding [FirewallBlockApp], Source={x:Static local:LocalizationManager.Instance}}"
                                    Click="FirewallBlockAppButton_Click" />
                            <Button x:Name="FirewallAllowSelectedButton" Margin="0,4,10,4" Padding="12,5" MinWidth="90" IsEnabled="False"
                                    Content="{Binding [FirewallAllowSelected], Source={x:Static local:LocalizationManager.Instance}}"
                                    Click="FirewallAllowSelectedButton_Click" />
                            <Button x:Name="FirewallBlockSelectedButton" Margin="0,4,10,4" Padding="12,5" MinWidth="90" IsEnabled="False"
                                    Content="{Binding [FirewallBlockSelected], Source={x:Static local:LocalizationManager.Instance}}"
                                    Click="FirewallBlockSelectedButton_Click" />
                            <Button x:Name="FirewallRemoveSelectedButton" Margin="0,4,10,4" Padding="12,5" MinWidth="90" IsEnabled="False"
                                    Content="{Binding [FirewallRemoveSelected], Source={x:Static local:LocalizationManager.Instance}}"
                                    Click="FirewallRemoveSelectedButton_Click" />
                            <Button x:Name="FirewallEmergencyButton" Margin="0,4,0,4" Padding="12,5" MinWidth="150"
                                    Background="#B91C1C" Foreground="White" BorderThickness="0" FontWeight="SemiBold"
                                    Content="{Binding [FirewallEmergencyDisable], Source={x:Static local:LocalizationManager.Instance}}"
                                    Click="FirewallEmergencyButton_Click" />
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Row="4" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="12">
                    <DataGrid x:Name="ResultsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              BorderThickness="0" AlternatingRowBackground="#F8FAFC" SelectionMode="Single"
                              SelectionChanged="ResultsGrid_SelectionChanged"
                              automation:AutomationProperties.Name="{Binding [ResultsAutomation], Source={x:Static local:LocalizationManager.Instance}}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{Binding [PriorityHeader], Source={x:Static local:LocalizationManager.Instance}}"
                                                Binding="{Binding SeverityLabel}" Width="125" />
                            <DataGridTextColumn Header="{Binding [ObservedItemHeader], Source={x:Static local:LocalizationManager.Instance}}"
                                                Binding="{Binding Title}" Width="2*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                        <Setter Property="ToolTip" Value="{Binding Title}" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="{Binding [FindingHeader], Source={x:Static local:LocalizationManager.Instance}}"
                                                Binding="{Binding Detail}" Width="3*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                                        <Setter Property="ToolTip" Value="{Binding Detail}" />
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <Border Grid.Row="5" Margin="0,12,0,0" Background="White" BorderBrush="#E2E8F0"
                        BorderThickness="1" CornerRadius="12" Padding="14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding [WhatToDo], Source={x:Static local:LocalizationManager.Instance}}"
                                       FontWeight="SemiBold" Foreground="#0F172A" />
                            <TextBlock x:Name="GuidanceText" Margin="0,4,10,0" TextWrapping="Wrap"
                                       Foreground="#475569"
                                       Text="{Binding [DefaultGuidance], Source={x:Static local:LocalizationManager.Instance}}" />
                            <TextBlock x:Name="SelectedFindingText" Margin="0,6,10,0" TextWrapping="Wrap"
                                       Foreground="#64748B" FontSize="12" />
                        </StackPanel>
                        <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                            <Button x:Name="OpenLocationButton"
                                    Content="{Binding [OpenFile], Source={x:Static local:LocalizationManager.Instance}}" IsEnabled="False"
                                    Click="OpenLocationButton_Click" />
                            <Button x:Name="CopyButton"
                                    Content="{Binding [CopyDetails], Source={x:Static local:LocalizationManager.Instance}}" IsEnabled="False"
                                    Click="CopyButton_Click" />
                            <Button x:Name="ExportButton"
                                    Content="{Binding [ExportJson], Source={x:Static local:LocalizationManager.Instance}}" IsEnabled="False"
                                    Click="ExportButton_Click" />
                        </WrapPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#E2E8F0" Padding="20,7">
            <TextBlock Foreground="#475569" FontSize="11"
                       Text="{Binding [ReadOnlyFooter], Source={x:Static local:LocalizationManager.Instance}}" />
        </Border>
    </Grid>
</Window>
