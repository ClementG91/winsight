<Window x:Class="WinSight.Dashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinSight" Height="680" Width="1080" MinHeight="500" MinWidth="780"
        Background="#F8FAFC" WindowStartupLocation="CenterScreen">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,18">
            <TextBlock FontSize="28" FontWeight="SemiBold" Foreground="#0F172A" Text="WinSight" />
            <TextBlock Margin="0,4,0,0" Foreground="#475569"
                       Text="Sécurité Windows transparente, locale et en lecture seule" />
        </StackPanel>

        <Border Grid.Row="1" Padding="14" CornerRadius="8" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
            <DockPanel LastChildFill="False">
                <ComboBox x:Name="ToolPicker" Width="230" Height="34" DisplayMemberPath="Label"
                          SelectedValuePath="Command" VerticalContentAlignment="Center" />
                <CheckBox x:Name="FlaggedOnly" Margin="18,0" VerticalAlignment="Center"
                          Content="Éléments notables uniquement" IsChecked="True" />
                <Button x:Name="ScanButton" Width="120" Height="34" Background="{StaticResource AccentBrush}"
                        Foreground="White" BorderThickness="0" Content="Analyser" Click="ScanButton_Click" />
            </DockPanel>
        </Border>

        <DockPanel Grid.Row="2" Margin="0,16,0,10">
            <TextBlock x:Name="SummaryText" VerticalAlignment="Center" FontWeight="SemiBold"
                       Foreground="#334155" Text="Prêt à analyser." />
            <ComboBox x:Name="ReportPicker" DockPanel.Dock="Right" Width="210" Visibility="Collapsed"
                      DisplayMemberPath="Tool" SelectionChanged="ReportPicker_SelectionChanged" />
        </DockPanel>

        <Border Grid.Row="3" Background="White" BorderBrush="#E2E8F0" BorderThickness="1" CornerRadius="8">
            <DataGrid x:Name="ResultsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                      CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      BorderThickness="0" AlternatingRowBackground="#F8FAFC">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Niveau" Binding="{Binding Severity}" Width="100" />
                    <DataGridTextColumn Header="Élément" Binding="{Binding Title}" Width="2*" />
                    <DataGridTextColumn Header="Détail" Binding="{Binding Detail}" Width="3*" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock Grid.Row="4" Margin="0,10,0,0" Foreground="#64748B" FontSize="12"
                   Text="Les analyses restent locales. VirusTotal n’est contacté que si WINSIGHT_VT_KEY est défini." />
    </Grid>
</Window>
